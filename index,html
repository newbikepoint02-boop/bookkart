// Create quick add buttons
function createQuickProducts() {
  const container = document.getElementById('quickProducts');
  container.innerHTML = quickProductsList.map((p, i) => 
    `<button onclick="quickAdd('${p.product}', '${p.brand}', ${p.rate})" style="padding:5px 10px; font-size:12px; background:#3498db; color:white; border:none; border-radius:4px; cursor:pointer;">${p.product} (₹${p.rate})</button>`
  ).join('');
}

function quickAdd(product, brand, rate) {
  const vehicle = vehicleInput.value.trim();
  const service = serviceNameInput.value.trim();
  const qty = parseInt(qtyInput.value, 10) || 1;
  
  items.push({ product, brand, rate, qty, vehicle, service });
  updateBill();
  
  // Show confirmation
  const btn = event.target;
  btn.style.background = '#27ae60';
  setTimeout(() => btn.style.background = '#3498db', 500);
}

// ==================== PRODUCT SUGGESTIONS ====================
let currentMatches = [];

function showSuggestions(query) {
  if (query.length < 1) {
    productSuggestions.style.display = 'none';
    return;
  }
  
  const q = query.toLowerCase();
  currentMatches = allProducts.filter(p => 
    p.product.toLowerCase().includes(q) || p.brand.toLowerCase().includes(q)
  ).slice(0, 15);
  
  if (currentMatches.length > 0) {
    productSuggestions.innerHTML = currentMatches.map((p, i) => 
      `<div onclick="selectProduct(${i})" style="padding:8px; cursor:pointer; border-bottom:1px solid #eee;">${p.product} - <strong>${p.brand}</strong> (₹${p.minRate}-${p.maxRate})</div>`
    ).join('');
    productSuggestions.style.display = 'block';
  } else {
    productSuggestions.style.display = 'none';
  }
}

function selectProduct(index) {
  const p = currentMatches[index];
  if (p) {
    productInput.value = p.product;
    brandInput.value = p.brand;
    rateInput.value = p.minRate;
    productSuggestions.style.display = 'none';
    
    // Auto-add to bill when product is selected
    autoAddToBill();
  }
}

function autoAddToBill() {
  const product = productInput.value.trim();
  const brand = brandInput.value.trim();
  const rate = parseFloat(rateInput.value);
  const qty = parseInt(qtyInput.value, 10) || 1;
  const vehicle = vehicleInput.value.trim();
  const service = serviceNameInput.value.trim();
  
  if (product && brand && rate > 0) {
    items.push({ product, brand, rate, qty, vehicle, service });
    clearInputs();
    updateBill();
  }
}

// Close suggestions when clicking outside
document.addEventListener('click', function(e) {
  if (!productInput.contains(e.target) && !productSuggestions.contains(e.target)) {
    productSuggestions.style.display = 'none';
  }
});

// ==================== ADD ITEM BUTTON ====================
// Auto-add random product from database when button is clicked
addItemButton.addEventListener('click', () => {
  const product = productInput.value.trim();
  const brand = brandInput.value.trim();
  const rate = parseFloat(rateInput.value);
  const qty = parseInt(qtyInput.value, 10);
  const vehicle = vehicleInput.value.trim();
  const service = serviceNameInput.value.trim();
  
  // If fields are empty, auto-add a random product from database
  if (!product || !brand || isNaN(rate) || rate <= 0) {
    const randomProduct = allProducts[Math.floor(Math.random() * allProducts.length)];
    const finalProduct = product || randomProduct.product;
    const finalBrand = brand || randomProduct.brand;
    const finalRate = rate || randomProduct.minRate;
    const finalQty = isNaN(qty) || qty <= 0 ? 1 : qty;
    
    items.push({ product: finalProduct, brand: finalBrand, rate: finalRate, qty: finalQty, vehicle, service });
    clearInputs();
    updateBill();
    return;
  }
  
  if (isNaN(qty) || qty <= 0) {
    alert('Please enter valid quantity.');
    return;
  }
  
  items.push({ product, brand, rate, qty, vehicle, service });
  clearInputs();
  updateBill();
});

function clearInputs() {
  productInput.value = '';
  brandInput.value = '';
  rateInput.value = '';
  qtyInput.value = '1';
}

// Auto-detect brand when rate is entered
rateInput.addEventListener('input', function() {
  const rate = parseFloat(this.value);
  if (rate > 0 && !brandInput.value) {
    // Auto-detect brand based on rate range
    if (rate <= 100) brandInput.value = 'Local';
    else if (rate <= 300) brandInput.value = 'TVS';
    else if (rate <= 600) brandInput.value = 'Bosch';
    else if (rate <= 1200) brandInput.value = 'Motul';
    else if (rate <= 2500) brandInput.value = 'MRF';
    else if (rate <= 4000) brandInput.value = 'Exide';
    else brandInput.value = 'Premium';
  }
});

// ==================== EXTRA CHARGES ====================
function addExtraCharge() {
  const name = document.getElementById('extraChargeName').value.trim();
  const amount = parseFloat(document.getElementById('extraChargeAmount').value);
  
  if (!name || isNaN(amount) || amount <= 0) {
    alert('Please enter valid charge name and amount.');
    return;
  }
  
  extraCharges.push({ name, amount });
  document.getElementById('extraChargeName').value = '';
  document.getElementById('extraChargeAmount').value = '';
  updateBill();
}

function removeExtraCharge(index) {
  extraCharges.splice(index, 1);
  updateBill();
}

// ==================== SERVICE CHARGE ====================
function updateServiceChargeDisplay() {
  const percent = parseFloat(document.getElementById('customServiceCharge').value) || 0;
  document.getElementById('serviceChargePercent').textContent = percent;
  document.getElementById('serviceChargeDisplay').textContent = percent;
  serviceChargePercent = percent;
  updateBill();
}

document.getElementById('applyServiceCharge').addEventListener('change', updateBill);

// ==================== UPDATE BILL ====================
function updateBill() {
  billBody.innerHTML = '';
  let subTotal = 0;
  
  if (items.length === 0) {
    billBody.innerHTML = '<tr><td colspan="8" style="text-align:center; color:#999; padding:20px;">No items added yet. Use quick buttons or search products above.</td></tr>';
  }
  
  items.forEach((item, index) => {
    const total = item.rate * item.qty;
    subTotal += total;
    const row = document.createElement('tr');
    row.style.background = index % 2 === 0 ? '#fff' : '#f8f8f8';
    row.innerHTML = `
      <td style="padding:10px;">${index + 1}</td>
      <td style="padding:10px;"><strong>${item.service || '-'}</strong></td>
      <td style="padding:10px;">${item.vehicle || '-'}</td>
      <td style="padding:10px; font-weight:bold; color:#2c3e50;">${item.product}</td>
      <td style="padding:10px;"><span style="background:#3498db; color:white; padding:2px 8px; border-radius:3px; font-size:12px;">${item.brand}</span></td>
      <td style="padding:10px;">₹${item.rate}</td>
      <td style="padding:10px;">${item.qty}</td>
      <td style="padding:10px; font-weight:bold; color:#27ae60;">₹${total}</td>
      <td style="padding:10px;"><button class="delete-btn" onclick="removeItem(${index})" style="padding:5px 8px;">✖</button></td>
    `;
    billBody.appendChild(row);
  });
  
  // Extra charges
  const extraChargesList = document.getElementById('extraChargesList');
  extraChargesList.innerHTML = '';
  let extraTotal = 0;
  extraCharges.forEach((charge, index) => {
    extraTotal += charge.amount;
    const div = document.createElement('div');
    div.className = 'extra-charge-item';
    div.innerHTML = `
      <span>${charge.name}: <strong>₹${charge.amount.toFixed(2)}</strong></span>
      <button class="delete-btn" onclick="removeExtraCharge(${index})">Remove</button>
    `;
    extraChargesList.appendChild(div);
  });
  
  // Service charge
  const applyServiceCharge = document.getElementById('applyServiceCharge').checked;
  const serviceChargeRow = document.getElementById('serviceChargeRow');
  const serviceChargeAmount = document.getElementById('serviceChargeAmount');
  
  if (applyServiceCharge) {
    serviceChargePercent = parseFloat(document.getElementById('customServiceCharge').value) || 10;
    const serviceAmount = (subTotal * serviceChargePercent) / 100;
    serviceChargeRow.style.display = 'block';
    serviceChargeAmount.textContent = `₹${serviceAmount.toFixed(2)}`;
    subTotal += serviceAmount;
  } else {
    serviceChargeRow.style.display = 'none';
  }
  
  // Update displays
  document.getElementById('subTotal').textContent = `₹${(subTotal - (applyServiceCharge ? (subTotal * serviceChargePercent / 100) : 0)).toFixed(2)}`;
  document.getElementById('extraChargesTotal').textContent = `₹${extraTotal.toFixed(2)}`;
  document.getElementById('grandTotal').textContent = `₹${(subTotal + extraTotal).toFixed(2)}`;
}

function removeItem(index) {
  items.splice(index, 1);
  updateBill();
}

// ==================== OWNER SETTINGS ====================
function saveOwnerSettings() {
  const serviceCharge = document.getElementById('defaultServiceCharge').value;
  const shopName = document.getElementById('shopName').value;
  const ownerName = document.getElementById('ownerName').value;
  
  localStorage.setItem('bikePointSettings', JSON.stringify({
    serviceCharge, shopName, ownerName
  }));
  
  document.getElementById('customServiceCharge').value = serviceCharge;
  document.getElementById('serviceChargePercent').textContent = serviceCharge;
  document.getElementById('serviceChargeDisplay').textContent = serviceCharge;
  serviceChargePercent = parseFloat(serviceCharge);
  
  alert('Settings saved successfully!');
}

// Load saved settings
window.addEventListener('load', function() {
  const saved = localStorage.getItem('bikePointSettings');
  if (saved) {
    const settings = JSON.parse(saved);
    document.getElementById('defaultServiceCharge').value = settings.serviceCharge || 10;
    document.getElementById('shopName').value = settings.shopName || 'New Bike Point';
    document.getElementById('ownerName').value = settings.ownerName || '';
    document.getElementById('customServiceCharge').value = settings.serviceCharge || 10;
    document.getElementById('serviceChargePercent').textContent = settings.serviceCharge || 10;
    document.getElementById('serviceChargeDisplay').textContent = settings.serviceCharge || 10;
    serviceChargePercent = parseFloat(settings.serviceCharge) || 10;
  }
  // Create quick add buttons
  createQuickProducts();
});

// ==================== PRINT & CLEAR ====================
function printBill() {
  if (items.length === 0 && extraCharges.length === 0) {
    alert('No items to print!');
    return;
  }
  window.print();
}

function clearBill() {
  if (confirm('Are you sure you want to clear all items?')) {
    items.length = 0;
    extraCharges.length = 0;
    updateBill();
  }
}
