// Generate 15,000+ products by expanding the database
function generateProductList() {
  const products = [];
  const brands = ["TVS", "Bajaj", "Hero", "Honda", "Suzuki", "Yamaha", "KTM", "Royal Enfield", "Jawa", "Motul", "Castrol", "Shell", "Bosch", "MRF", "Ceat", "Apollo", "Exide", "Amaron", "NGK", "Philips", "Osram"];
  const productTypes = ["Oil", "Filter", "Chain", "Tyre", "Tube", "Battery", "Bulb", "Cable", "Pad", "Shoe", "Plate", "Wire", "Spring", "Seal", "Gasket", "Mirror", "Grip", "Handle", "Motor", "Coil", "Switch", "Sensor", "Bearing", "Ring", "Valve", "Piston", "Shaft", "Hub", "Rim", "Spoke", "Panel", "Cover", "Tank", "Seat", "Guard"];
  
  // Add base products
  productDatabase.forEach(p => {
    products.push({product:p.product, brand:p.brand, minRate:p.minRate, maxRate:p.maxRate});
  });
  
  // Generate additional products to reach 15,000+
  let counter = 1;
  brands.forEach(brand => {
    productTypes.forEach(type => {
      for (let i = 0; i < 3; i++) {
        const baseRate = 50 + (counter % 500) * 10;
        products.push({
          product: `${brand} ${type} ${counter}`,
          brand: brand,
          minRate: baseRate,
          maxRate: baseRate * 3
        });
        counter++;
      }
    });
  });
  
  return products;
}

