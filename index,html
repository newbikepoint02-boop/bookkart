  .product-suggestions div:hover { background: #3498db; color: white; }
  .input-group { position: relative; }
  .delete-btn { background: #e74c3c; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; }
  .owner-settings { background: #f39c12; padding: 15px; border-radius: 8px; margin-top: 20px; color: white; }
